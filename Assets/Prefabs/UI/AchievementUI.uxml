<ui:UXML xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" editor-extension-mode="False">
    <Style src="project://database/Assets/Prefabs/UI/AchievmentStyles.uss?fileID=7433441132597879392&amp;guid=52872424e690542c3b4b43758714f5d8&amp;type=3#AchievmentStyles"/>
    <ui:VisualElement style="flex-grow: 1; justify-content: flex-end;">
        <ui:VisualElement name="PopupContainer" class="popup-container">
            <ui:VisualElement name="Icon" class="popup-icon"/>
            <ui:VisualElement class="text-container">
                <ui:Label name="Title" text="SYSTEM UPDATE" class="popup-title"/>
                <ui:Label name="Description" text="ACHIEVEMENT UNLOCKED..." class="popup-desc"/>
            </ui:VisualElement>
        </ui:VisualElement>
    </ui:VisualElement>
</ui:UXML>
